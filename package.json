{
  "name": "everyone-is-john",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "cd client && npm run dev",
    "start": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "start:server": "tsx watch server/index.ts",
    "start:client": "cd client && npm run dev",
    "start:prod": "node server/dist/server/index.js",
    "kill-port": "npx --yes kill-port 3000",
    "build": "npm run build:server && npm run build:client",
    "build:server": "cd server && tsc",
    "build:client": "cd client && npm run build",
    "deploy:client": "npm run build:client && aws s3 sync client/dist s3://YOUR_BUCKET --delete",
    "deploy:server": "npm run build:server && echo 'rsync server/dist to EC2, pm2 restart'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "concurrently": "^8.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
